# asdf/mise tool versions for this app repo's dev + Claude Code environment.
# Managed fleet-wide by thinkpod's Terraform (terraform/github/templates/
# tool-versions.tftpl) and pushed to every app repo, so the toolset evolves from
# one place -- like publish.yml/lint.yml/CLAUDE.md. Edit it in skylartaylor/thinkpod,
# not here. Lives at the repo ROOT (not .github/) because asdf/mise only discover
# .tool-versions at the root and ancestor dirs. `latest` keeps the toolchain current
# without churning this file on every upstream release.
awscli latest
sops latest
helm latest
kubectl latest
flux2 latest
github-cli latest
